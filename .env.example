# Niuma AI Agent - 环境变量配置示例
# 复制此文件为 .env 并填入你的实际值

# ============================================================================
# LLM 配置
# ============================================================================

# 选择 LLM 提供商: openai 或 anthropic
LLM_PROVIDER=openai

# --- OpenAI 配置 ---
# OpenAI API Key (必需，如果使用 OpenAI)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI 模型名称 (可选，默认: gpt-4o)
# 可以是任意 OpenAI 兼容模型: gpt-4o, gpt-4o-mini 等
OPENAI_MODEL=gpt-4o

# 自定义 OpenAI API 基础 URL (可选，用于第三方代理)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic 配置 ---
# Anthropic API Key (必需，如果使用 Anthropic)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Anthropic 模型名称 (可选，默认: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# 自定义 Anthropic API 基础 URL (可选)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- LLM 通用参数 ---
# 温度参数 (0.0 - 2.0, 默认: 0.7)
LLM_TEMPERATURE=0.7

# 最大生成令牌数 (可选，默认: 不限制)
# LLM_MAX_TOKENS=4096

# API 请求超时时间 (秒, 默认: 60)
LLM_TIMEOUT=60

# API 失败重试次数 (默认: 3)
LLM_RETRY_COUNT=3

# ============================================================================
# 记忆系统配置
# ============================================================================

# 向量存储路径 (默认: .niuma/vector_store)
MEMORY_VECTOR_STORE_PATH=.niuma/vector_store

# SQLite 数据库路径 (默认: .niuma/memory.db)
MEMORY_SQLITE_PATH=.niuma/memory.db

# 短期记忆窗口大小 (轮数, 默认: 10)
MEMORY_STM_WINDOW_SIZE=10

# 短期记忆压缩阈值 (默认: 20)
MEMORY_STM_COMPRESSION_THRESHOLD=20

# 向量嵌入模型 (默认: text-embedding-3-small)
MEMORY_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# Agent 运行时配置
# ============================================================================

# 最大并发 Agent 数量 (默认: 5)
AGENT_MAX_CONCURRENCY=5

# 默认任务超时时间 (秒, 默认: 300)
AGENT_DEFAULT_TIMEOUT=300

# 任务最大重试次数 (默认: 3)
AGENT_MAX_RETRIES=3

# ============================================================================
# Worktree 隔离配置
# ============================================================================

# Worktree 基础路径 (默认: .niuma/worktrees)
WORKTREE_BASE_PATH=.niuma/worktrees

# 最大活动 worktree 数量 (默认: 10)
WORKTREE_MAX_WORKTREES=10

# 自动清理非活动 worktree (默认: true)
WORKTREE_AUTO_CLEANUP=true

# ============================================================================
# 应用程序配置
# ============================================================================

# 调试模式 (默认: false)
DEBUG=false

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL, 默认: INFO)
LOG_LEVEL=INFO

# 数据目录 (默认: .niuma)
DATA_DIR=.niuma
